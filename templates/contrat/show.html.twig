{% extends 'base.html.twig' %}

{% block title %}
	{{ contrat.nom }}
	{{ contrat.prenom }}
	- DocManager
{% endblock %}

{% block body %}
	<div class="page-header">
		<div>
			<h1 class="page-title">👤
				{{ contrat.nom }}
				{{ contrat.prenom }}</h1>
			<p class="page-subtitle">contrat details and documents</p>
		</div>
		<div class="page-actions">
			{% if is_granted('contrat_MANAGE') %}
				<a href="{{ path('app_contrat_edit', {id: contrat.id}) }}" class="btn btn-secondary">✏️ Edit</a>
			{% endif %}
			{% if is_granted('DOCUMENT_MANAGE') %}
				<a href="{{ path('app_document_new', {id: contrat.id}) }}" class="btn btn-primary">📄 Upload</a>
			{% endif %}
		</div>
	</div>

	{# Stats #}
	<div class="stats-grid">
		<div class="stat-card">
			<div class="stat-icon cyan">📄</div>
			<div>
				<div class="stat-value">{{ contrat.documents|length }}</div>
				<div class="stat-label">Documents</div>
			</div>
		</div>
		<div class="stat-card">
			<div class="stat-icon green">📅</div>
			<div>
				<div class="stat-value">{{ contrat.createdAt|date('d/m') }}</div>
				<div class="stat-label">Since</div>
			</div>
		</div>
	</div>

	{# contrat Details #}
	<div class="card">
		<div class="card-header">
			<h2 class="card-title">📋 contrat Details</h2>
		</div>
		<div class="detail-list">
			<div class="detail-item">
				<div class="detail-label">Full Name</div>
				<div class="detail-value">{{ contrat.nom }}
					{{ contrat.prenom }}</div>
			</div>
			 
			 
			 
			<div class="detail-item">
				<div class="detail-label">Created</div>
				<div class="detail-value">{{ contrat.createdAt|date('d/m/Y H:i') }}</div>
			</div>
		</div>
	</div>

	{# Documents #}
	<div class="card" style="padding: 0; overflow: hidden;">
		<div class="card-header">
			<h2 class="card-title">📄 Documents ({{ contrat.documents|length }})</h2>
			<a href="{{ path('app_document_new', {id: contrat.id}) }}" class="btn btn-sm btn-primary">➕ Upload</a>
		</div>

		{% if contrat.documents is empty %}
			<div class="empty-state">
				<div class="empty-state-icon">📂</div>
				<h3>No documents yet</h3>
				<p>Upload the first document for this contrat.</p>
			</div>
		{% else %}
			<div class="table-container">
				<table>
					<thead>
						<tr>
							<th>Title</th>
							<th>File</th>
							<th>Size</th>
							<th>Uploaded</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for doc in contrat.documents %}
							<tr>
								<td>
									<a href="{{ path('app_document_show', {id: doc.id}) }}" style="font-weight: 600;">{{ doc.title }}</a>
								</td>
								<td class="text-muted">{{ doc.originalName ?? doc.fileName ?? '—' }}</td>
								<td>
									{% if doc.size %}
										{{ (doc.size / 1024)|number_format(1) }}
										KB
									{% else %}
										<span class="text-muted">—</span>
									{% endif %}
								</td>
								<td class="text-muted">{{ doc.createdAt|date('d/m/Y') }}</td>
								<td>
									<div style="display: flex; gap: 0.5rem;">
										<a href="{{ path('app_document_download', {id: doc.id}) }}" class="btn btn-sm btn-success">⬇</a>
										<a href="{{ path('app_document_show', {id: doc.id}) }}" class="btn btn-sm btn-secondary">View</a>
										<form method="post" action="{{ path('app_document_delete', {id: doc.id}) }}" class="inline-form" onsubmit="return confirm('Delete this document?');">
											<input type="hidden" name="_token" value="{{ csrf_token('delete-document-' ~ doc.id) }}">
											<button type="submit" class="btn btn-sm btn-danger">🗑</button>
										</form>
									</div>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% endif %}
	</div>

	 
{% endblock %}
