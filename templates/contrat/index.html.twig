{% extends 'base.html.twig' %}

{% block title %}contrat - DocManager{% endblock %}

{% block body %}
	<div class="page-header">
		<div>
			<h1 class="page-title">Contrats</h1>
			<p class="page-subtitle">Gestion des contrats et documents</p>
		</div>
		<div class="page-actions">
			<form method="POST" action="{{ path('app_contrat_sync') }}" style="display: inline;">
				<input type="hidden" name="_token" value="{{ csrf_token('sync-contrats') }}">
				<button type="submit" class="btn btn-secondary" onclick="this.disabled=true; this.innerHTML='Synchronisation...'; this.form.submit();">
					Synchroniser
				</button>
			</form>
		</div>
	</div>

	{# Flash messages #}
	{% for message in app.flashes('success') %}
		<div class="alert alert-success" style="margin-bottom: 1rem;">{{ message }}</div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="alert alert-danger" style="margin-bottom: 1rem;">{{ message }}</div>
	{% endfor %}

	{# Stats #}
	<div class="stats-grid">
		<div class="stat-card">
			<div class="stat-icon cyan">👥</div>
			<div>
				<div class="stat-value">{{ totalContrats }}</div>
				<div class="stat-label">Total contrat</div>
			</div>
		</div>
	</div>

	{# Search & Filters #}
	<div class="card" style="padding: 1rem; margin-bottom: 1.5rem;">
		<form method="GET" action="{{ path('app_contrat_index') }}" style="display: flex; gap: 0.5rem;">
			<div class="search-box" style="flex: 1;">
				<span class="search-box-icon">🔍</span>
				<input type="search" name="search" class="form-control" placeholder="Rechercher par nom ou prenom..." value="{{ search }}">
			</div>
			<button type="submit" class="btn btn-primary">Rechercher</button>
			{% if search %}
				<a href="{{ path('app_contrat_index') }}" class="btn btn-secondary">Effacer</a>
			{% endif %}
		</form>
	</div>

	{% if contrats is empty %}
		<div class="card">
			<div class="empty-state">
				<div class="empty-state-icon">👥</div>
				<h3>No contrat yet</h3>
				<p>Create your first contrat to start managing documents.</p>
				{% if is_granted('contrat.create') %}
					<a href="{{ path('app_contrat_new') }}" class="btn btn-primary">➕ Create contrat</a>
				{% endif %}
			</div>
		</div>
	{% else %}
		<div class="card" style="padding: 0; overflow: hidden;">
			<div class="table-container">
				<table id="contratTable">
					<thead>
						<tr>
						   <th>id</th>
							<th>Name</th>
							 
							{# Documents column - controlled by permission #}
							{% if is_granted('contrats.view_documents_column') %}
								<th>Documents</th>
							{% endif %}
							<th>Created</th>
							{# Actions column - controlled by permission #}
							{% if is_granted('contrat.view_actions_column') %}
								<th>Actions</th>
							{% endif %}
						</tr>
					</thead>
					<tbody>
						{% for contrat in contrats %}
							<tr>
								<td>{{ contrat.id }}</td>
								<td>
									{# Name always shown, but link controlled by permission #}
									{% if is_granted('contrat.view_details') %}
										<a href="{{ path('app_contrat_show', {id: contrat.id}) }}" style="font-weight: 600; color: var(--text-primary);">
											{{ contrat.nom }}
											{{ contrat.prenom }}
										</a>
									{% else %}
										<span style="font-weight: 600; color: var(--text-primary);">
											{{ contrat.nom }}
											{{ contrat.prenom }}
										</span>
									{% endif %}
								</td>
								{# <td>{{ contrat.email ?? '<span class="text-muted">—</span>'|raw }}</td>
								<td>{{ contrat.phone ?? '<span class="text-muted">—</span>'|raw }}</td> #}
								{# Documents column - controlled by permission #}
								{% if is_granted('contrats.view_documents_column') %}
									<td>
										<span class="badge badge-cyan">{{ contrat.documents|length }}</span>
									</td>
								{% endif %}
								{# <td class="text-muted">{{ contrat.createdAt|date('d/m/Y') }}</td> #}
								{# Actions column - controlled by permission #}
								{% if is_granted('ROLE_ADMIN') or is_granted('contrats.view_actions_column') or app.user == contrat.user or app.user.externalId == contrat.externalUserId %}
									<td>
										<div style="display: flex; gap: 0.5rem;">
											{# View button - controlled by permission #}
											{% if is_granted('contrats.view_view_button') or app.user == contrat.user or app.user.externalId == contrat.externalUserId %}
												<a href="{{ path('app_contrat_show', {id: contrat.id}) }}" class="btn btn-sm btn-secondary">View</a>
											{% endif %}
											{# Documents button - controlled by document view permission OR if user owns the contrat #}
											{% if is_granted('documents.view_list') or app.user == contrat.user or app.user.externalId == contrat.externalUserId %}
												<a href="{{ path('app_document_list', {id: contrat.id}) }}" class="btn btn-sm btn-primary" title="View Documents">📄</a>
											{% endif %}
										</div>
									</td>
								{% endif %}
							</tr>
						{% endfor %}
					</tbody>
					
				</table>
				{% if totalPages > 1 %}
    <div class="card" style="padding: 1rem; margin-top: 1rem;">
        <div style="display: flex; justify-content: center; gap: 0.5rem; align-items: center;">
            {% if currentPage > 1 %}
                <a href="{{ path('app_contrat_index', {page: currentPage - 1, search: search}) }}" class="btn btn-sm btn-secondary">
                    Precedent
                </a>
            {% endif %}

            <span>Page {{ currentPage }} / {{ totalPages }}</span>

            {% if currentPage < totalPages %}
                <a href="{{ path('app_contrat_index', {page: currentPage + 1, search: search}) }}" class="btn btn-sm btn-secondary">
                    Suivant
                </a>
            {% endif %}
        </div>
    </div>
{% endif %}
			</div>
		</div>
	{% endif %}
{% endblock %}
